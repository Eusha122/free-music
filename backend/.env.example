# Postgres password used by both the db and api services
POSTGRES_PASSWORD=change_me

# Long random string used to sign auth JWTs, e.g. `openssl rand -hex 32`
JWT_SECRET=change_me

# Free client id from https://devportal.jamendo.com/
JAMENDO_CLIENT_ID=

# Any identifier string Audius uses to attribute API traffic to your app
AUDIUS_APP_NAME=FreeTuneApp
